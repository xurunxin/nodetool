{
  "name": "@nodetool-ai/nodes-utils",
  "version": "0.7.0-rc.23",
  "description": "Shared helpers for node packages: platform tags and lazy Node-only module loaders",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-typescript-workspace.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@nodetool-ai/protocol": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "nodetool-dev": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dashscope": {
      "nodetool-dev": "./src/providers/dashscope.ts",
      "types": "./dist/providers/dashscope.d.ts",
      "import": "./dist/providers/dashscope.js",
      "default": "./dist/providers/dashscope.js"
    },
    "./kling": {
      "nodetool-dev": "./src/providers/kling.ts",
      "types": "./dist/providers/kling.d.ts",
      "import": "./dist/providers/kling.js",
      "default": "./dist/providers/kling.js"
    },
    "./volcengine": {
      "nodetool-dev": "./src/providers/volcengine.ts",
      "types": "./dist/providers/volcengine.d.ts",
      "import": "./dist/providers/volcengine.js",
      "default": "./dist/providers/volcengine.js"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nodetool-ai/nodetool.git",
    "directory": "packages/nodes-utils"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "README.md"]
}
